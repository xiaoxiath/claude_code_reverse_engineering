{
  "name": "claude-code-restored",
  "version": "3.0.0",
  "description": "Claude Code — 基于 Bun 2.1.83 二进制深度逆向分析的参考实现",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --compile --outfile claude-code",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "fmt": "biome format --write src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.0",
    "cli-spinners": "^3.2.0",
    "execa": "^9.5.0",
    "globby": "^14.0.0",
    "ink": "^5.1.0",
    "react": "^18.3.0",
    "strip-ansi": "^7.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "@types/react": "^18.3.0",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@anthropic-ai/sdk"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "UNLICENSED",
  "private": true
}
