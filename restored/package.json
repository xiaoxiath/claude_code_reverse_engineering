{
  "name": "claude-code-restored",
  "version": "2.1.83",
  "description": "Claude Code - Restored from Bun 2.1.83 binary",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --compile --outfile claude-code",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "trustedDependencies": [
    "@anthropic-ai/sdk"
  ]
}
